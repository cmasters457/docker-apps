POSTGRES_USER=<sqluser>
POSTGRES_PASSWORD=<sqlpassword>
POSTGRES_DB=<postgresdb>

SECRET_KEY_BASE=<64char-random>
SELF_HOSTED="true"
RAILS_FORCE_SSL="false"
RAILS_ASSUME_SSL="false"
DB_HOST=postgres
DB_PORT=5432
REDIS_URL=redis://redis:6379/1
